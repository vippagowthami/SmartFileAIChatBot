{
  "development": {
    "backend_url": "http://localhost:8000",
    "frontend_port": 8080,
    "ollama_base_url": "http://localhost:11434",
    "default_model": "functiongemma",
    "debug": true
  },
  "rag_config": {
    "chunk_size": 800,
    "chunk_overlap": 150,
    "num_retrieval": 3,
    "temperature": 0.1,
    "top_p": 0.9,
    "relevance_threshold": 0.5
  },
  "database": {
    "type": "chromadb",
    "path": "./data/chroma_db",
    "collection_name": "documents",
    "embedding_model": "all-minilm"
  },
  "logging": {
    "log_dir": "./logs",
    "log_level": "INFO",
    "log_format": "json"
  },
  "file_processing": {
    "supported_formats": [".txt", ".pdf", ".docx", ".doc", ".csv", ".json", ".xlsx", ".xls"],
    "max_file_size_mb": 50,
    "encoding": "utf-8",
    "chunk_size_tokens": 600,
    "chunk_overlap_tokens": 120
  },
  "cors": {
    "allow_origins": ["*"],
    "allow_credentials": true,
    "allow_methods": ["*"],
    "allow_headers": ["*"]
  }
}
